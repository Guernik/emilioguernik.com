---
import BaseLayout from "@layouts/BaseLayout.astro"
import Prose from "@components/common/Prose.astro"
import PostTags from "@components/common/PostTags.astro"
import Back from "@components/common/Back.astro"
import { formatDate } from "@utils/formatDate"

const { frontmatter, readingTime } = Astro.props
const { title, description, date, tags } = frontmatter.data

const formattedDate = formatDate(date, "long")
---

<BaseLayout title={title} description={description}>
  <Prose class="has-dropcap">
    <h1>{title}</h1>

    <div class="not-prose -mt-4 mb-8 flex items-center gap-x-3">
      <time datetime={date} class="almanac-smallcaps">{formattedDate}</time>
      <hr class="rule-hair grow" />
      <span class="almanac-smallcaps">{readingTime}</span>
    </div>

    <slot />

    <PostTags tags={tags} />

    <Back label="Back to Writings" href="/writings" class="mt-8" />
  </Prose>
</BaseLayout>
