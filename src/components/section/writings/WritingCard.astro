---
import type { CollectionEntry } from "astro:content"

import { formatDate } from "@utils/formatDate"

interface Props {
  writingEntry: CollectionEntry<"writings">
}

const { writingEntry } = Astro.props
const { title, description, date, tags } = writingEntry.data
const formattedDate = formatDate(date, "medium")
---

<a
  href={`/${writingEntry.collection}/${writingEntry.id}`}
  class="group -m-4 flex flex-col gap-y-1 rounded-sm bg-card/0 p-4 transition-colors duration-200 ease-out hover:bg-card/75"
>
  <span class="almanac-smallcaps">{formattedDate}</span>

  <h2
    class="font-display text-lg font-medium tracking-tight text-foreground decoration-primary/40 underline-offset-4 transition-all duration-200 ease-out group-hover:underline group-hover:decoration-primary/70"
    style="font-optical-sizing: auto; font-variation-settings: 'opsz' 40;"
  >
    {title}
  </h2>
  {
    description && (
      <p class="leading-normal text-muted-foreground">{description}</p>
    )
  }
</a>
