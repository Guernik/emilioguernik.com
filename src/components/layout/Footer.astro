---
import { config } from "@parseConfig"

const year = new Date().getFullYear()
---

<footer class="mt-16 pt-8">
  <hr class="rule-double mb-4" />
  <div
    class="flex items-baseline justify-between gap-x-4 text-xs text-muted-foreground sm:text-sm"
  >
    <p>
      &copy; {year} &nbsp;
      <span
        class="font-display font-medium text-foreground/80"
        style="font-optical-sizing: auto; font-variation-settings: 'opsz' 24;"
        >{config.site.author}</span
      >
    </p>
  </div>
</footer>
