---
import { ClientRouter } from "astro:transitions"
import { config } from "@parseConfig"

// Preload the two above-the-fold display fonts. Importing the woff2 with
// `?url` lets Astro emit the content-hashed path and hand back the resolved
// URL, so these preloads never go stale when the font package updates.
// Without them the browser only discovers the fonts after Prose.css parses,
// which pushes them onto the LCP critical path (see PageSpeed dependency tree).
import frauncesUrl from "@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url"
import geistUrl from "@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url"

interface Props {
  title: string
  description: string
  image?: string
}

const { title: pageTitle, description: pageDescription, image } = Astro.props

const siteName = config.site.title
const isHome = Astro.url.pathname === "/"
const fullTitle = isHome
  ? siteName
  : pageTitle
    ? `${pageTitle} — ${siteName}`
    : siteName
const description = pageDescription || config.site.description
const socialImage = new URL(image || "/og-image.png", config.site.url)
const canonicalURL = new URL(Astro.url.pathname, config.site.url)

// Keep the canonical production domain indexable; any other host this is
// built for (the hackwhite.com Cloudflare mirror) is a performance testbed
// and should stay out of search results to avoid duplicate content.
const isCanonicalHost = config.site.url === "https://emilioguernik.com"
---

{/* Global Metadata */}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

{/* Preload above-the-fold fonts so they're not blocked on CSS parse.
    crossorigin is required for fonts even when same-origin. */}
<link
  rel="preload"
  href={frauncesUrl}
  as="font"
  type="font/woff2"
  crossorigin
/>
<link rel="preload" href={geistUrl} as="font" type="font/woff2" crossorigin />

<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={config.site.author} />

{/* Canonical URL */}
<link rel="canonical" href={canonicalURL} />

{/* Primary Meta Tags */}
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<link rel="sitemap" href="/sitemap-index.xml" />

{/* Open Graph / Facebook */}
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />

{/* Twitter */}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />

{/* Favicons */}
<link
  rel="icon"
  type="image/png"
  href="/favicons/favicon-96x96.png"
  sizes="96x96"
/>
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicons/favicon.ico" />
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/favicons/apple-touch-icon.png"
/>

{/* App */}
<meta name="apple-mobile-web-app-title" content={siteName} />
<link rel="manifest" href="/favicons/site.webmanifest" />

{/* Optional */}
<meta
  name="robots"
  content={isCanonicalHost ? "index, follow" : "noindex, nofollow"}
/>

{/* View Transition API */}
<ClientRouter />

{/*
  Speed up the browser's default root cross-fade. The UA default is ~0.25s;
  shortening it makes navigation feel snappier without removing the fade.
*/}
<style is:global>
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.08s;
    animation-timing-function: ease-out;
  }
</style>
